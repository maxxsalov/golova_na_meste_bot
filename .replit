modules = ["python-3.12"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start Bot"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start Scheduler"

[[workflows.workflow]]
name = "Start Bot"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python -m bot.main"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Start Scheduler"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python -m scheduler.main"

[workflows.workflow.metadata]
outputType = "console"

[deployment]
deploymentTarget = "vm"
run = ["bash", "-c", "python -m bot.main & python -m scheduler.main & wait"]
